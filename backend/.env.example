ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
LLAMA_CLOUD_API_KEY=llx-xxxxxxxxxxxxxxxxxxxx   # Optional: for LlamaParse PDF parsing

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=docuforge_chunks

# Job store (SQLite — no separate service required)
JOB_DB_PATH=./jobs.db

# Generation Settings
MAX_RETRIES_PER_SECTION=3
CHILD_CHUNK_SIZE=250          # tokens
PARENT_CHUNK_SIZE=1500        # tokens
RETRIEVAL_TOP_K=6             # chunks to retrieve per section

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
